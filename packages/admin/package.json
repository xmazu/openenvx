{
  "name": "@openenvx/admin",
  "version": "0.3.0",
  "type": "module",
  "author": {
    "email": "xmazu@yahoo.com",
    "name": "xmazu"
  },
  "description": "Standalone admin panel",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rolldown -c && tsc --emitDeclarationOnly && tailwindcss -i ./src/styles/globals.css --content './src/**/*.{tsx,ts}' -o ./dist/styles.css",
    "dev": "rolldown -c --watch",
    "typecheck": "tsc --noEmit || true",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jose": "^6.0.10",
    "lucide-react": "^1.7.0",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "next": "^16.2.1",
    "postcss-cli": "^11.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rolldown": "^1.0.0-rc.11",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-table": "^8.21.3",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "zod": "^4.3.6"
  },
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./client/styles.css": {
      "import": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  }
}
