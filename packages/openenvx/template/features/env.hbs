{{#if (or (eq database 'postgres') (eq database 'postgresql'))}}
# Database (local development via oexctl)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
{{/if}}

{{#if features.stripe}}
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
{{/if}}
{{#if features.storage}}
# S3 Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=
{{/if}}
{{#if features.email}}
# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
{{/if}}
