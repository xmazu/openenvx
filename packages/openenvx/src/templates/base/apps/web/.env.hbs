# Database
DATABASE_URL=postgresql://user:password@localhost:5432/{{projectName}}

{{#if hasOexctl}}
# Proxy URLs (using oexctl)
WEB_URL=https://{{projectName}}-web.localhost:1355
DASHBOARD_URL=https://{{projectName}}-dashboard.localhost:1355
{{else}}
# Fallback ports (install oexctl for better URLs: openenvx install)
WEB_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001
{{/if}}

# Auth
BETTER_AUTH_SECRET=your-secret-key
BETTER_AUTH_URL=${DASHBOARD_URL}
